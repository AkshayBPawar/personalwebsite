{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/css/*", "/js/*", "*.css", "*.js", "*.png", "*.jpg", "*.svg", "*.pdf"]
  },
  "globalHeaders": {
    "cache-control": "public, max-age=0, must-revalidate"
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
